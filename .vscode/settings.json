{
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/.DS_Store": true
  },
  "search.exclude": {
    "external/imgui/*": true
  },
  "C_Cpp.intelliSenseEngine": "disabled",
  "clangd.arguments": [
    "-j=2",
    "--compile-commands-dir=build",
    "--pch-storage=disk",
    "--completion-style=bundled",
    "--limit-results=50",
    "--header-insertion=never"
  ]
}
